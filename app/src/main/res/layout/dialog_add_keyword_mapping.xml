<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_add_keyword_mapping.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter the keyword and the absolute paths to pre-recorded audio files. Or use the Studio tabs to record and auto-link."
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNewKeyword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Keyword (e.g. market, station)"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNewKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLength="50" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- GENTS path -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="♂ GENTS audio path (optional)"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="/data/data/.../files/audio/gents/responses/..."
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etGentsPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textSize="12sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- LADY path -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="♀ LADY audio path (optional)"
        android:textSize="12sp"
        android:textColor="#AD1457"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="/data/data/.../files/audio/lady/responses/..."
        android:layout_marginBottom="4dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etLadyPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textSize="12sp" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
