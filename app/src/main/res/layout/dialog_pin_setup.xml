<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_pin_setup.xml — Used ONLY on first launch to set the PIN -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Security Code"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create a code to protect advanced system settings."
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginBottom="16dp" />

    <!-- Current PIN input — only shown/used by AdminActivity's change-PIN flow.
         Hidden (and untouched) during first-launch setup via MainActivity. -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCurrentPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Current Security Code"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCurrentPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="8" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- New PIN input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="New Security Code"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNewPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="8" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm PIN input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Confirm Security Code"
        android:layout_marginBottom="8dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfirmPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="8"
            android:imeOptions="actionDone" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Validation error message — empty by default, shown on mismatch -->
    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#C62828"
        android:layout_marginTop="4dp" />

</LinearLayout>
