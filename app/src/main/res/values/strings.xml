    <!--
        This is the string the OS displays:
          - In the app launcher
          - In recent apps list
          - In Settings → Apps

        It must look like a legitimate system utility.
    -->
    <string name="app_name">System Cache Manager</string>
    <string name="app_name_stealth">System Cache Manager</string>

